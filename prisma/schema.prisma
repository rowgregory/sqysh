// ─────────────────────────────────────────────────────────────────────────────
// SQYSH — Prisma schema
//
// workflow:
//   npx prisma db push
//   npx prisma generate
//
// conventions:
//   - models PascalCase, tables/columns snake_case via @@map/@map
//   - cuid ids everywhere
//   - createdAt/updatedAt on anything a human creates
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgbouncer) — runtime
  directUrl = env("DIRECT_URL") // direct — migrations
}

// ── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_USER
  ADMIN
  SQYSHLING // client — one of ours
  GHOST // went dark
}

enum InquiryStatus {
  NEW
  CONTACTED
  IN_DISCUSSION
  WON
  CLOSED
  SCAM
}

enum ShopOrderStatus {
  PENDING // row created, Printful order not yet placed
  SUBMITTED // sent to Printful successfully
  FULFILLMENT_FAILED // Printful rejected it — needs your attention
  SHIPPED
}

// ── Models ────────────────────────────────────────────────────────────────────

model Inquiry {
  id        String        @id @default(cuid())
  name      String        @db.VarChar(120)
  company   String?       @map("company_name") @db.VarChar(160)
  email     String        @db.VarChar(254)
  phone     String?       @db.VarChar(30)
  message   String
  status    InquiryStatus @default(NEW)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([status, createdAt(sort: Desc)])
  @@map("inquiries")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique @db.VarChar(254)
  // NextAuth-required fields:
  name          String?   @db.VarChar(160)
  image         String?   @db.Text
  emailVerified DateTime? @map("email_verified")
  // your existing fields — made nullable so OAuth sign-in doesn't violate NOT NULL:
  firstName     String?   @map("first_name") @db.VarChar(80)
  lastName      String?   @map("last_name") @db.VarChar(80)
  phone         String?   @db.VarChar(30)
  company       String?   @db.VarChar(50)
  role          Role      @default(SQYSHLING)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model TrafficSource {
  id        String   @id @default(cuid())
  source    String   @unique @db.VarChar(60) // the utm_source value: "pride-banner", "core"
  count     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("traffic_sources")
}

model GameScore {
  id        String   @id @default(cuid())
  score     Int
  initials  String?  @db.VarChar(3) // null = didn't qualify / didn't claim
  country   String?  @db.VarChar(2) // "US" — from Vercel geo headers
  region    String?  @db.VarChar(40) // "MA"
  city      String?  @db.VarChar(80) // "Swampscott"
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([score(sort: Desc), createdAt(sort: Asc)])
  @@index([createdAt(sort: Desc)])
  @@map("game_scores")
}

model ShopOrder {
  id String @id @default(cuid())

  // ─ idempotency key: the unique constraint IS the dedupe mechanism ─
  stripeSessionId     String  @unique @map("stripe_session_id")
  stripePaymentIntent String? @map("stripe_payment_intent")

  items Json // [{ printfulVariantId, productName, colorway, size, quantity, unitAmount }]

  // ─ money (snapshot at purchase) ─
  amountTotal Int    @map("amount_total") // cents, from Stripe
  currency    String @default("usd")

  // ─ fulfillment ─
  status          ShopOrderStatus @default(PENDING)
  printfulOrderId Int?            @map("printful_order_id")
  failureReason   String?         @map("failure_reason")

  // ─ who / where (geo from Vercel headers, like GameScore) ─
  email   String
  country String?
  region  String?
  city    String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  trackingNumber String? @map("tracking_number")
  trackingUrl    String? @map("tracking_url") @db.Text
  carrier        String?

  printfulCost Int? @map("printful_cost") // cents, what Printful charges you

  @@index([status, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("shop_orders")
}

model CatalogCache {
  id        String   @id @default("singleton") // one row
  data      Json // the full getCatalog() output
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("catalog_cache")
}
